{
  "compilerOptions": {
    /* Environment Settings */
    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2024",
    "lib": ["es2024"],
    "types": ["node"],

    /* Decorators for TypeGraphQL */
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "outDir": "dist",
  }
}


